# Google AI Studio API Key (get yours at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Veea Lobster Trap DPI Proxy URL (optional — defaults to http://localhost:8080)
# If not configured, the app gracefully falls back to direct API endpoints
LOBSTER_TRAP_URL=http://localhost:8080
